{
  "Version": "2012-10-17",
  "Statement": [

    {
      "Sid": "ListBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::s3-bucket-cloud-nova"
    },

    {
      "Sid": "GetAndPutObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::s3-bucket-cloud-nova"
    }

  ]
}
