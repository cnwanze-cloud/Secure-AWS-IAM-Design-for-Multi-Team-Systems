{
  "Version": "2012-10-17",
  "Statement": [
    
    {
      "Sid": "EC2FullAccess",
      "Effect": "Allow",
      "Action": "ec2:*",
      "Resource": "*"
    },

    {
      "Sid": "S3ReadWriteAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::s3-bucket-cloud-nova",      ]
    },

    {
      "Sid": "DenyIAMAccess",
      "Effect": "Deny",
      "Action": "iam:*",
      "Resource": "*"
    },

    {
      "Sid": "DenyBillingAccess",
      "Effect": "Deny",
      "Action": [
        "aws-portal:*",
        "budgets:*",
        "cur:*",
        "ce:*"
      ],
      "Resource": "*"
    }

  ]
}
